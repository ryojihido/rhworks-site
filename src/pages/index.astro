---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import WorksSection from '../components/home/WorksSection.astro';
import VideosSection from '../components/home/VideosSection.astro';
import ProfileSection from '../components/home/ProfileSection.astro';
import LabSection from '../components/home/LabSection.astro';
import AlphabetaBridge from '../components/home/AlphabetaBridge.astro';
import ContactSection from '../components/home/ContactSection.astro';
---

<Layout
  title="RHworks | 氷堂リョージ - 漫画家"
  description="漫画家・氷堂リョージの公式サイト。作品紹介、プロフィール、最新情報をお届けします。"
  socialImage="/og/rhworks-share.png"
  socialImageAlt="RHworksの公式サイト共有サムネイル"
>
  <div class="relative">
    <img src="/images/home/hero-wreath.webp" alt="" aria-hidden="true" class="hero-illustration" />

    <main class="max-w-5xl mx-auto px-6 md:px-10 relative z-10">
      <Hero />
      <WorksSection />
      <ProfileSection />
      <LabSection />
      <AlphabetaBridge />
      <VideosSection />
      <ContactSection />

      <footer class="pt-10 pb-16 border-t border-brand-gray/10 text-center">
        <p class="text-[10px] tracking-[0.4em] text-brand-gray/30 uppercase">&copy; {new Date().getFullYear()} RHworks Ryoji Hido</p>
      </footer>
    </main>
  </div>
</Layout>

<style>
  /* Decorative wreath: single top-right bleed behind Hero, fading out where opaque
     content (Works cards) begins. Must stay a sibling of <main>, not a descendant —
     see local-notes/redesign-v3/ judgment log for why the stacking order inverts otherwise. */
  .hero-illustration {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 0;
    width: clamp(520px, 58vw, 860px);
    aspect-ratio: 1;
    transform: translate(22%, -14%) rotate(-10deg);
    opacity: 0.35;
    filter: saturate(90%);
    pointer-events: none;
  }
  @media (max-width: 767px) {
    .hero-illustration {
      width: 100vw;
      transform: translate(45%, -20%) rotate(-10deg);
      opacity: 0.3;
    }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-illustration {
      width: 52vw;
      transform: translate(30%, -14%) rotate(-10deg);
    }
  }
</style>
