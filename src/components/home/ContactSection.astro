---
---

<section id="contact" class="py-20 border-t border-brand-gray/10" x-data="{ copied: false }">
  <div class="max-w-xl mx-auto text-center space-y-6">
    <h2 class="text-sm font-bold tracking-[0.3em] uppercase text-brand-gray/50">Contact</h2>
    <p class="text-sm text-brand-gray/60 font-serif leading-relaxed">
      制作のご依頼や、作品に関するお問い合わせはこちらまで。<br />
      For project inquiries or collaborations.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="mailto:ryojihido@gmail.com" class="inline-block px-6 py-3 bg-brand-ink text-brand-beige rounded-xl font-bold text-xs tracking-widest uppercase hover:-translate-y-0.5 transition-all">
        ryojihido@gmail.com
      </a>
      <button
        @click="navigator.clipboard.writeText('ryojihido@gmail.com'); copied = true; setTimeout(() => copied = false, 1800)"
        class="px-4 py-3 border border-brand-gray/20 rounded-xl text-[10px] font-bold tracking-widest uppercase text-brand-gray/60 hover:border-brand-pink-accent/50 transition-all"
      >
        <span x-text="copied ? 'コピーしました' : 'コピー'"></span>
      </button>
    </div>
    <p class="text-[10px] tracking-[0.3em] uppercase text-brand-gray/35">Kanagawa, Japan</p>
  </div>
</section>
