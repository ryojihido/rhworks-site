---
import { works, featuredRecommendation } from '../../data/works';
---

<section id="works" class="py-20 space-y-10" x-data="mangaPreviewPage()">
  <div class="flex items-end justify-between border-b border-brand-gray/10 pb-4">
    <h2 class="text-sm font-bold tracking-[0.3em] uppercase text-brand-gray/50">Works</h2>
    <span class="text-[10px] font-mono text-brand-gray/40">{works.length} titles + latest</span>
  </div>

  <!-- Latest work -->
  <div class="rounded-2xl border border-brand-gray/10 bg-white p-6 md:p-8">
    <div class="grid grid-cols-1 md:grid-cols-[160px,1fr] gap-6 items-center">
      <a
        href={featuredRecommendation.url}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="block aspect-[3/4] w-full max-w-[160px] mx-auto md:mx-0 rounded-xl overflow-hidden border border-brand-gray/10 shadow-sm"
      >
        <img
          src={`/images/thumbnails/${featuredRecommendation.image}`}
          alt={featuredRecommendation.title}
          class="w-full h-full object-cover"
        />
      </a>
      <div class="space-y-2 text-center md:text-left">
        <div class="flex flex-wrap items-center justify-center md:justify-start gap-2">
          <span class="inline-block px-2.5 py-1 text-[9px] font-bold tracking-widest uppercase text-brand-pink-accent border border-brand-pink-accent/40 rounded-full">Latest</span>
          <span class="inline-block px-2.5 py-1 text-[9px] font-bold tracking-widest uppercase text-brand-gray/50 border border-brand-gray/15 rounded-full">{featuredRecommendation.format}</span>
        </div>
        <h3 class="text-2xl md:text-3xl font-serif font-bold text-gray-900">{featuredRecommendation.title}</h3>
        <p class="text-sm text-brand-gray/60 font-serif">{featuredRecommendation.subtitle}</p>
        <p class="text-sm font-serif italic leading-relaxed text-brand-gray/75">{featuredRecommendation.quote}</p>
        <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 pt-1">
          <button
            type="button"
            @click={`activeWork = ${JSON.stringify(featuredRecommendation)}; openViewer()`}
            class="text-[10px] font-bold tracking-widest uppercase text-brand-pink-accent border-b border-brand-pink-accent/40 hover:text-brand-gray"
          >
            試し読み
          </button>
          <a
            href={featuredRecommendation.url}
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="text-[10px] font-bold tracking-widest uppercase text-brand-gray/50 border-b border-brand-gray/20 hover:text-brand-pink-accent"
          >
            {featuredRecommendation.ctaLabel}
          </a>
        </div>
        {featuredRecommendation.isAffiliate && (
          <p class="text-[10px] leading-relaxed text-brand-gray/45">
            Amazonボタンにはアフィリエイトリンクを使用しています。
          </p>
        )}
      </div>
    </div>
  </div>

  <!-- Grid -->
  <div class="relative">
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4 max-h-[560px] overflow-hidden" :style="open ? 'max-height: none; overflow: visible;' : ''">
      {works.map((work) => (
        <button
          type="button"
          @click={`activeWork = ${JSON.stringify(work)}; modalOpen = true`}
          class="group flex flex-col rounded-xl border border-brand-gray/10 bg-white/60 p-2 hover:border-brand-pink-accent/50 hover:shadow-md transition-all duration-300"
        >
          <div class="aspect-[3/4] rounded-lg overflow-hidden">
            <img
              src={`/images/thumbnails/${work.image}`}
              alt={work.title}
              class={`w-full h-full ${work.modalImageContain ? 'object-contain p-2 bg-brand-beige/40' : 'object-cover'}`}
            />
          </div>
          <span class="mt-2 text-[10px] leading-tight text-brand-gray/70 line-clamp-2 text-left">{work.title}</span>
        </button>
      ))}
    </div>
    <div x-show="!open" class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-brand-beige to-transparent pointer-events-none"></div>
  </div>

  <button
    @click="open = !open"
    class="w-full py-3 text-[10px] font-bold tracking-[0.25em] uppercase border border-brand-gray/15 hover:border-brand-pink-accent/50 transition-all rounded-full text-brand-gray/60"
  >
    <span x-text={`open ? '閉じる' : 'すべて見る（${works.length}作品）'`}>{`すべて見る（${works.length}作品）`}</span>
  </button>

  <!-- Detail modal -->
  <template x-teleport="body">
    <div
      x-show="modalOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-8 bg-brand-ink/90 backdrop-blur-sm"
      @keydown.escape.window="if (!viewerOpen && !viewerClosing) modalOpen = false"
    >
      <div
        @click.away="if (!viewerOpen && !viewerClosing) modalOpen = false"
        class="relative w-full max-w-4xl max-h-[90vh] bg-brand-beige rounded-2xl shadow-2xl overflow-hidden flex flex-col md:flex-row"
      >
        <button
          @click="modalOpen = false"
          class="absolute top-4 right-4 z-10 p-2.5 rounded-full bg-brand-ink/80 hover:bg-brand-ink text-brand-beige border border-white/10 transition-all"
          aria-label="Close details popup"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="flex-1 bg-brand-ink/95 flex items-center justify-center p-5 md:p-8">
          <div
            class="w-full max-w-md rounded-xl overflow-hidden border border-white/10 shadow-2xl bg-black/30 flex items-center justify-center"
            :class="activeWork?.modalImageContain ? 'p-4' : 'aspect-[3/4]'"
          >
            <img
              :src="activeWork ? `/images/thumbnails/${activeWork.image}` : ''"
              :alt="activeWork?.title"
              :class="activeWork?.modalImageContain ? 'max-w-full max-h-[68vh] object-contain rounded-lg' : 'w-full h-full object-cover'"
            />
          </div>
        </div>

        <div class="w-full md:w-[380px] bg-brand-beige p-8 overflow-y-auto">
          <div class="space-y-6">
            <div class="space-y-3">
              <span class="inline-block px-2.5 py-1 text-[10px] font-bold tracking-widest uppercase text-brand-pink-accent border border-brand-pink-accent/40 rounded-full" x-text="activeWork?.format">Selected Work</span>
              <h3 class="text-2xl font-serif font-bold text-gray-900 leading-tight" x-text="activeWork?.title">Title</h3>
              <p class="text-sm font-serif italic leading-relaxed text-brand-gray/75" x-text="activeWork?.summary">Summary</p>
            </div>

            <div class="space-y-3">
              <h4 class="text-[10px] font-bold tracking-widest uppercase text-brand-gray/50 border-b border-brand-gray/10 pb-2">Details</h4>
              <ul class="space-y-2">
                <template x-for="detail in activeWork?.details" :key="detail">
                  <li class="text-sm text-brand-gray/75 flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-pink-accent shrink-0"></span>
                    <span x-text="detail">Detail</span>
                  </li>
                </template>
              </ul>
            </div>

            <div class="space-y-3">
              <template x-if="activeWork?.previewPages && activeWork.previewPages.length > 0">
                <button
                  type="button"
                  @click="openViewer()"
                  class="inline-flex w-full items-center justify-center rounded-xl border border-brand-gray text-brand-gray px-5 py-3 text-xs font-bold tracking-widest uppercase hover:bg-brand-gray hover:text-brand-beige transition-all"
                >
                  試し読み
                </button>
              </template>

              <a
                :href="activeWork?.url"
                target="_blank"
                :rel="activeWork?.isAffiliate ? 'noopener noreferrer sponsored' : 'noopener noreferrer'"
                class="inline-flex w-full items-center justify-center rounded-xl bg-brand-ink px-5 py-3 text-xs font-bold tracking-widest uppercase text-brand-beige transition-all hover:shadow-lg"
              >
                <span x-text="activeWork?.ctaLabel">Amazonで見る</span>
              </a>

              <p x-show="activeWork?.isAffiliate" class="text-[10px] leading-relaxed text-brand-gray/45">
                Amazonボタンにはアフィリエイトリンクを使用しています。
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </template>

  <!-- Manga Preview Viewer (nested, spread-aware) -->
  <template x-teleport="body">
    <div
      x-show="viewerOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-[60] bg-brand-ink/95 backdrop-blur-xl"
      @keydown.escape.window="if (viewerOpen) closeViewer()"
      @keydown.arrow-left.window="if (viewerOpen) nextSlide()"
      @keydown.arrow-right.window="if (viewerOpen) prevSlide()"
      style="display: none;"
    >
      <div class="absolute top-0 inset-x-0 z-10 flex items-center justify-between gap-4 px-5 md:px-8 py-5 bg-gradient-to-b from-brand-ink via-brand-ink/80 to-transparent">
        <div class="min-w-0 flex-1">
          <p class="text-[10px] font-bold tracking-[0.3em] uppercase text-brand-pink-accent/80">Preview</p>
          <h3 class="mt-1 text-sm md:text-base font-serif text-brand-beige truncate" x-text="activeWork?.title"></h3>
        </div>
        <div class="flex items-center gap-4 shrink-0">
          <span
            class="text-brand-beige/70 text-[11px] font-bold tracking-[0.2em] tabular-nums uppercase"
            x-text="slides.length === 0 ? '...' : (isAffiliateSlide ? 'Fin' : ((viewerSlideIndex + 1) + ' / ' + slides.length))"
          ></span>
          <button
            type="button"
            @click.stop="closeViewer()"
            class="p-3 rounded-full bg-brand-ink/80 hover:bg-brand-ink text-brand-beige border border-white/10 transition-all"
            aria-label="Close preview viewer"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
      </div>

      <div
        class="h-full w-full flex items-center justify-center px-4 md:px-24 lg:px-32 xl:px-36 pt-24 pb-12"
        @touchstart="touchStartX = $event.touches[0].clientX"
        @touchend="swipeEnd($event)"
      >
        <template x-if="slides.length === 0">
          <div class="flex items-center gap-3 text-brand-beige/60">
            <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-opacity="0.25"></circle><path d="M12 2a10 10 0 0110 10" stroke-linecap="round"></path></svg>
            <span class="text-[10px] font-bold tracking-[0.3em] uppercase">Loading Preview</span>
          </div>
        </template>

        <template x-if="slides.length > 0 && !isAffiliateSlide && slides[viewerSlideIndex]?.type === 'spread'">
          <img
            :src="slides[viewerSlideIndex].page"
            alt=""
            class="max-h-full max-w-full object-contain select-none pointer-events-none rounded-xl shadow-2xl"
            draggable="false"
          />
        </template>

        <template x-if="slides.length > 0 && !isAffiliateSlide && slides[viewerSlideIndex]?.type === 'single-full'">
          <img
            :src="slides[viewerSlideIndex].page"
            alt=""
            class="max-h-full max-w-full object-contain select-none pointer-events-none rounded-xl shadow-2xl"
            draggable="false"
          />
        </template>

        <template x-if="slides.length > 0 && !isAffiliateSlide && slides[viewerSlideIndex]?.type === 'spread-half'">
          <div
            class="relative max-h-full max-w-full overflow-hidden rounded-xl shadow-2xl"
            style="width: min(calc(100vw - 2rem), calc(70.3125vh - 6.328125rem)); aspect-ratio: 720 / 1024;"
          >
            <img
              :src="slides[viewerSlideIndex].page"
              alt=""
              class="absolute top-0 h-full w-auto max-w-none select-none pointer-events-none"
              :class="slides[viewerSlideIndex].side === 'right' ? 'right-0' : 'left-0'"
              draggable="false"
            />
          </div>
        </template>

        <template x-if="slides.length > 0 && !isAffiliateSlide && slides[viewerSlideIndex]?.type === 'pair'">
          <div class="grid h-full w-full max-w-full grid-cols-2 items-center gap-0">
            <div class="flex h-full min-w-0 items-center justify-end">
              <img
                :src="slides[viewerSlideIndex].left"
                alt=""
                class="max-h-full max-w-full object-contain select-none pointer-events-none rounded-l-xl shadow-2xl"
                draggable="false"
              />
            </div>
            <div class="flex h-full min-w-0 items-center justify-start">
              <img
                :src="slides[viewerSlideIndex].right"
                alt=""
                class="max-h-full max-w-full object-contain select-none pointer-events-none rounded-r-xl shadow-2xl"
                draggable="false"
              />
            </div>
          </div>
        </template>

        <template x-if="slides.length > 0 && !isAffiliateSlide && slides[viewerSlideIndex]?.type === 'single-left'">
          <div class="grid h-full w-full max-w-full grid-cols-2 items-center gap-0">
            <div class="flex h-full min-w-0 items-center justify-end">
              <img
                :src="slides[viewerSlideIndex].page"
                alt=""
                class="max-h-full max-w-full object-contain select-none pointer-events-none rounded-xl shadow-2xl"
                draggable="false"
              />
            </div>
            <div aria-hidden="true"></div>
          </div>
        </template>

        <template x-if="slides.length > 0 && !isAffiliateSlide && slides[viewerSlideIndex]?.type === 'single-right'">
          <div class="grid h-full w-full max-w-full grid-cols-2 items-center gap-0">
            <div
              x-show="viewerSlideIndex === slides.length - 1"
              class="flex h-full min-w-0 items-center justify-center px-4"
            >
              <div class="flex max-h-full w-full max-w-xs flex-col items-center justify-center gap-3 text-center">
                <div class="flex items-center gap-3">
                  <span class="w-2 h-2 bg-brand-pink-accent rotate-45"></span>
                  <p class="text-brand-pink-accent/90 text-[10px] font-bold tracking-[0.3em] uppercase">Fin</p>
                  <span class="w-2 h-2 bg-brand-pink-accent rotate-45"></span>
                </div>
                <a
                  :href="activeWork?.url"
                  target="_blank"
                  :rel="activeWork?.isAffiliate ? 'noopener noreferrer sponsored' : 'noopener noreferrer'"
                  class="block group"
                >
                  <div
                    class="rounded-xl bg-brand-ink/5 overflow-hidden relative border border-brand-gray/10 shadow-2xl p-2 transition-all group-hover:scale-[1.02]"
                    :class="activeWork?.modalImageContain ? 'p-4' : ''"
                  >
                    <img
                      :src="'/images/thumbnails/' + activeWork?.image"
                      :alt="activeWork?.title"
                      class="max-h-[24vh] w-auto mx-auto rounded-lg"
                      :class="activeWork?.modalImageContain ? 'object-contain' : ''"
                    />
                  </div>
                </a>
                <div class="space-y-1">
                  <h4 class="text-brand-beige text-base font-serif font-bold" x-text="activeWork?.title"></h4>
                  <p class="text-brand-beige/70 text-xs font-serif italic">続きは本編で。</p>
                </div>
                <a
                  :href="activeWork?.url"
                  target="_blank"
                  :rel="activeWork?.isAffiliate ? 'noopener noreferrer sponsored' : 'noopener noreferrer'"
                  class="inline-flex items-center justify-center rounded-xl bg-brand-beige px-6 py-3 text-xs font-bold tracking-widest uppercase text-brand-gray transition-all hover:shadow-xl"
                >
                  <span x-text="activeWork?.ctaLabel"></span>
                </a>
                <p x-show="activeWork?.isAffiliate" class="text-[10px] leading-relaxed text-brand-beige/50">
                  Amazonボタンにはアフィリエイトリンクを使用しています。
                </p>
                <template x-if="activeWork?.takecomiUrl">
                  <div class="w-full space-y-2 border-t border-brand-beige/10 pt-2">
                    <a
                      :href="activeWork?.takecomiUrl"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group block rounded-xl border border-white/80 bg-white px-4 py-3 shadow-sm transition-all hover:shadow-xl"
                    >
                      <img
                        :src="activeWork?.takecomiBanner"
                        alt="竹コミ！"
                        class="mx-auto h-auto w-full max-w-[14rem] transition-transform group-hover:scale-[1.03]"
                      />
                    </a>
                    <p class="text-[10px] leading-relaxed text-brand-beige/65" x-text="activeWork?.takecomiComment"></p>
                  </div>
                </template>
              </div>
            </div>
            <div x-show="viewerSlideIndex !== slides.length - 1" aria-hidden="true"></div>
            <div class="flex h-full min-w-0 items-center justify-start">
              <img
                :src="slides[viewerSlideIndex].page"
                alt=""
                class="max-h-full max-w-full object-contain select-none pointer-events-none rounded-xl shadow-2xl"
                draggable="false"
              />
            </div>
          </div>
        </template>

        <template x-if="isAffiliateSlide">
          <div class="flex flex-col items-center justify-center gap-6 max-w-sm text-center">
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 bg-brand-pink-accent rotate-45"></span>
              <p class="text-brand-pink-accent/90 text-[10px] font-bold tracking-[0.3em] uppercase">Fin</p>
              <span class="w-2 h-2 bg-brand-pink-accent rotate-45"></span>
            </div>
            <a
              :href="activeWork?.url"
              target="_blank"
              :rel="activeWork?.isAffiliate ? 'noopener noreferrer sponsored' : 'noopener noreferrer'"
              class="block group"
            >
              <div
                class="rounded-2xl bg-brand-ink/5 overflow-hidden relative border border-brand-gray/10 shadow-2xl p-3 transition-all group-hover:scale-[1.02]"
                :class="activeWork?.modalImageContain ? 'p-4' : ''"
              >
                <img
                  :src="'/images/thumbnails/' + activeWork?.image"
                  :alt="activeWork?.title"
                  class="max-h-[34vh] w-auto mx-auto rounded-xl"
                  :class="activeWork?.modalImageContain ? 'object-contain' : ''"
                />
              </div>
            </a>
            <div class="space-y-2">
              <h4 class="text-brand-beige text-lg font-serif font-bold" x-text="activeWork?.title"></h4>
              <p class="text-brand-beige/70 text-sm font-serif italic">続きは本編で。</p>
            </div>
            <a
              :href="activeWork?.url"
              target="_blank"
              :rel="activeWork?.isAffiliate ? 'noopener noreferrer sponsored' : 'noopener noreferrer'"
              class="inline-flex items-center justify-center rounded-xl bg-brand-beige px-8 py-4 text-sm font-bold tracking-widest uppercase text-brand-gray transition-all hover:shadow-xl"
            >
              <span x-text="activeWork?.ctaLabel"></span>
            </a>
            <p x-show="activeWork?.isAffiliate" class="text-[10px] leading-relaxed text-brand-beige/50">
              Amazonボタンにはアフィリエイトリンクを使用しています。
            </p>
            <template x-if="activeWork?.takecomiUrl">
              <div class="w-full space-y-3 border-t border-brand-beige/10 pt-4">
                <a
                  :href="activeWork?.takecomiUrl"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded-xl border border-white/80 bg-white px-5 py-4 shadow-sm transition-all hover:shadow-xl"
                >
                  <img
                    :src="activeWork?.takecomiBanner"
                    alt="竹コミ！"
                    class="mx-auto h-auto w-full max-w-[18rem] transition-transform group-hover:scale-[1.03]"
                  />
                </a>
                <p class="text-xs leading-relaxed text-brand-beige/65" x-text="activeWork?.takecomiComment"></p>
              </div>
            </template>
          </div>
        </template>
      </div>

      <button
        type="button"
        @click="nextSlide()"
        :disabled="viewerSlideIndex >= totalViewerSlides - 1"
        aria-label="次のページ"
        class="absolute left-8 lg:left-12 top-1/2 hidden -translate-y-1/2 p-4 rounded-full bg-brand-ink/60 hover:bg-brand-ink text-brand-beige border border-white/10 transition-all disabled:opacity-20 disabled:pointer-events-none md:flex"
      >
        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>
      <button
        type="button"
        @click="prevSlide()"
        :disabled="viewerSlideIndex === 0"
        aria-label="前のページ"
        class="absolute right-8 lg:right-12 top-1/2 hidden -translate-y-1/2 p-4 rounded-full bg-brand-ink/60 hover:bg-brand-ink text-brand-beige border border-white/10 transition-all disabled:opacity-20 disabled:pointer-events-none md:flex"
      >
        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </button>
    </div>
  </template>
</section>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    window.Alpine.data('mangaPreviewPage', () => ({
      open: false,
      modalOpen: false,
      activeWork: null,

      viewerOpen: false,
      viewerClosing: false,
      viewerSlideIndex: 0,
      slides: [],
      imageAspects: {},
      touchStartX: 0,

      async openViewer() {
        this.viewerSlideIndex = 0;
        this.viewerOpen = true;
        this.slides = [];
        await this.buildSlides();
      },
      closeViewer() {
        this.viewerClosing = true;
        this.viewerOpen = false;
        this.viewerSlideIndex = 0;
        setTimeout(() => { this.viewerClosing = false; }, 0);
      },
      async buildSlides() {
        const pages = this.activeWork?.previewPages;
        if (!pages || pages.length === 0) { this.slides = []; return; }

        const aspects = await Promise.all(pages.map(src => this.getAspect(src)));
        const isMobile = window.innerWidth < 768;
        const slides = [];

        if (isMobile) {
          for (let i = 0; i < pages.length; i++) {
            if (aspects[i] > 1) {
              slides.push({ type: 'spread-half', page: pages[i], side: 'right' });
              slides.push({ type: 'spread-half', page: pages[i], side: 'left' });
            } else {
              slides.push({ type: 'single-full', page: pages[i] });
            }
          }
          this.slides = slides;
          return;
        }

        let i = 0;
        while (i < pages.length) {
          const isSpread = aspects[i] > 1;
          if (isSpread) {
            slides.push({ type: 'spread', page: pages[i] });
            i++;
          } else if (i === 0) {
            slides.push({ type: 'single-left', page: pages[i] });
            i++;
          } else if (i + 1 < pages.length && aspects[i + 1] <= 1) {
            slides.push({ type: 'pair', right: pages[i], left: pages[i + 1] });
            i += 2;
          } else {
            slides.push({ type: 'single-right', page: pages[i] });
            i++;
          }
        }
        this.slides = slides;
      },
      getAspect(src) {
        return new Promise(resolve => {
          if (this.imageAspects[src]) { resolve(this.imageAspects[src]); return; }
          const img = new Image();
          img.onload = () => {
            const ratio = img.naturalWidth / img.naturalHeight;
            this.imageAspects[src] = ratio;
            resolve(ratio);
          };
          img.onerror = () => resolve(0.7);
          img.src = src;
        });
      },
      get hasInlineFinalCta() {
        const lastSlide = this.slides[this.slides.length - 1];
        return lastSlide?.type === 'single-right';
      },
      get totalViewerSlides() { return this.slides.length + (this.hasInlineFinalCta ? 0 : 1); },
      get isAffiliateSlide() { return !this.hasInlineFinalCta && this.slides.length > 0 && this.viewerSlideIndex === this.slides.length; },
      nextSlide() { if (this.viewerSlideIndex < this.totalViewerSlides - 1) this.viewerSlideIndex++; },
      prevSlide() { if (this.viewerSlideIndex > 0) this.viewerSlideIndex--; },
      swipeEnd(e) {
        const dx = e.changedTouches[0].clientX - this.touchStartX;
        if (Math.abs(dx) < 40) return;
        dx > 0 ? this.nextSlide() : this.prevSlide();
      },
    }));
  });
</script>
