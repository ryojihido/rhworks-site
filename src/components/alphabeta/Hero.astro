---
---
<section class="relative py-20 md:py-32 overflow-hidden bg-brand-surface">
  <div class="absolute inset-0 bg-brand-pink/5 opacity-50"></div>
  <div class="container mx-auto px-8 relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
      
      <!-- Text Content -->
      <div class="flex-1 space-y-8 text-center md:text-left order-2 md:order-1">
        <div class="space-y-4">
          <div class="inline-block px-4 py-1.5 text-[10px] font-bold tracking-[0.2em] text-brand-pink-accent bg-brand-pink/30 rounded-full uppercase">
            Project a-b-lab
          </div>
          <h1 class="text-6xl md:text-8xl font-serif font-bold tracking-tight text-gray-900 italic">
            αβlab
          </h1>
          <h2 class="text-xl md:text-2xl font-serif font-bold text-brand-gray/90 leading-tight">
            生成AIを安全に試せる、<br class="hidden sm:block" />オリジナルキャラクター配布企画
          </h2>
          <div class="space-y-6">
            <p class="text-base text-brand-gray/70 font-serif italic max-w-lg mx-auto md:mx-0 leading-relaxed">
              配布キャラの画像を生成AIに読み込ませて、衣装や雰囲気、構図のアレンジを自由に試せます。<br class="hidden sm:block" />
              権利関係のクリアな「ルールのある白地」から、新しい表現を始められる企画です。
            </p>

            <!-- Usage Flow -->
            <div class="flex flex-col sm:flex-row gap-6 md:gap-8 py-8 border-y border-brand-pink/10">
              <div class="flex items-center gap-3 md:gap-4 group">
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-pink/20 text-brand-pink-accent flex items-center justify-center font-bold text-xs ring-4 ring-brand-pink/5 group-hover:bg-brand-pink-accent group-hover:text-white transition-all duration-300">1</span>
                <span class="text-[10px] md:text-[11px] font-bold tracking-wider text-brand-gray/80 uppercase text-left">公式画像を<br class="hidden md:block" />ダウンロード</span>
              </div>
              <div class="flex items-center gap-3 md:gap-4 group">
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-pink/20 text-brand-pink-accent flex items-center justify-center font-bold text-xs ring-4 ring-brand-pink/5 group-hover:bg-brand-pink-accent group-hover:text-white transition-all duration-300">2</span>
                <span class="text-[10px] md:text-[11px] font-bold tracking-wider text-brand-gray/80 uppercase text-left">生成AIで<br class="hidden md:block" />アレンジを試行</span>
              </div>
              <div class="flex items-center gap-3 md:gap-4 group">
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-pink/20 text-brand-pink-accent flex items-center justify-center font-bold text-xs ring-4 ring-brand-pink/5 group-hover:bg-brand-pink-accent group-hover:text-white transition-all duration-300">3</span>
                <span class="text-[10px] md:text-[11px] font-bold tracking-wider text-brand-gray/80 uppercase text-left">非商用での<br class="hidden md:block" />SNS投稿OK</span>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start pt-4">
          <a 
            href="#how-to-use" 
            class="inline-block px-8 py-4 bg-brand-gray text-brand-beige rounded-2xl font-bold hover:shadow-xl hover:-translate-y-1 transition-all text-[11px] tracking-[0.2em] uppercase text-center"
          >
            使い方を見る
          </a>
          <a 
            href="/alphabeta/guidelines/" 
            class="inline-block px-8 py-4 bg-white border border-brand-pink/30 text-brand-pink-accent rounded-2xl font-bold hover:bg-brand-pink/5 hover:shadow-lg hover:-translate-y-1 transition-all text-[11px] tracking-[0.2em] uppercase text-center"
          >
            利用ルールを見る
          </a>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="flex-1 order-1 md:order-2 w-full max-w-md md:max-w-none">
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-br from-brand-pink/40 to-brand-pink-accent/20 rounded-[3rem] blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
          <div class="relative aspect-square rounded-[3rem] bg-brand-pink/5 border border-brand-pink/10 overflow-hidden shadow-2xl">
            <img 
              src="/images/alphabeta/hero.webp" 
              alt="αβlab Hero Character" 
              class="w-full h-full object-cover grayscale brightness-110 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-1000"
            />
            <div class="absolute inset-0 bg-brand-pink-accent/10 mix-blend-multiply group-hover:opacity-0 transition-opacity duration-700"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
