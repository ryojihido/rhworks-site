---
const rules = [
  { item: "商用利用", status: "NG", detail: "営利目的（収益化、広告、販売等）での利用は禁止です。" },
  { item: "AI学習", status: "NG", detail: "再配布を目的としたモデル化（LoRA等）は禁止されています。" },
  { item: "二次創作", status: "OK", detail: "非営利の範囲であれば、SNS投稿やファンアートを歓迎します。" },
  { item: "再配布", status: "NG", detail: "素材そのものの再配布・転売は禁止です。" }
];
---
<section id="rules" class="py-20 bg-brand-beige">
  <div class="container mx-auto px-8 max-w-3xl">
    <h2 class="text-sm font-bold tracking-[0.3em] uppercase text-brand-pink-accent/80 mb-8">Rules (Quick Reference)</h2>
    <div class="bg-white/50 backdrop-blur-sm rounded-3xl border border-brand-pink/20 overflow-hidden shadow-sm">
      <div class="divide-y divide-brand-pink/10">
        {rules.map(rule => (
          <div class="flex flex-col sm:flex-row sm:items-center p-6 gap-4">
            <div class="flex items-center gap-4 sm:w-1/3">
              <span class={`px-3 py-1 text-[10px] font-bold rounded-full ${rule.status === 'OK' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                {rule.status}
              </span>
              <span class="font-bold text-gray-900">{rule.item}</span>
            </div>
            <p class="text-sm text-brand-gray/70 sm:w-2/3 italic">
              {rule.detail}
            </p>
          </div>
        ))}
      </div>
    </div>
    <p class="mt-8 text-[10px] text-brand-gray/40 text-center uppercase tracking-widest">
      ※ 詳細は<a href="/alphabeta/guidelines/" class="text-brand-pink-accent hover:underline">利用規約</a>をご確認ください
    </p>
  </div>
</section>
