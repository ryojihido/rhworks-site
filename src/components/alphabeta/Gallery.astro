---
interface GalleryItem {
  id: string;
  title: string;
  thumb: string;
  image: string;
  tools: string[];
  category: string;
  summary: string;
  promptNote: string[];
  promptExample?: string;
}

const items: GalleryItem[] = [
  {
    id: "01",
    title: "継承体α - カラーリンクによる背景生成",
    thumb: "/images/alphabeta/gallery/thumb_01.webp",
    image: "/images/alphabeta/gallery/01.webp",
    tools: ["Gemini Nanobanana"],
    category: "Gemini Nanobanana",
    summary: "αの私室デザイン。希望する雰囲気やαに使われたカラーリングに合わせる指示（プロンプト）によって生成。",
    promptNote: [
      "Workspace setup",
      "Alpha color palette",
      "Lo-fi aesthetic",
      "Cluttered tech desk"
    ],
    promptExample: "A cozy workspace for Alpha, 3 monitors, gaming chair, technical equipment on desk, soft indoor lighting, lofi anime style, vibrant orange and teal accents.",
  },
  {
    id: "02",
    title: "編纂体β - デジタル近未来都市の風景",
    thumb: "/images/alphabeta/gallery/thumb_02.webp",
    image: "/images/alphabeta/gallery/02.webp",
    tools: ["Gemini Nanobanana"],
    category: "Gemini Nanobanana",
    summary: "βの歩く未来都市。βのカラーリングに合わせた淡い色と、ペットのロボデザインを指示（プロンプト）によって生成。",
    promptNote: [
      "Futuristic city",
      "Beta color palette",
      "Neon pastel aesthetic",
      "Robotic companion"
    ],
    promptExample: "Beta walking in a futuristic neon city at sunset, pastel cyberpunk colors, small robotic drone flying beside her, cinematic soft glow.",
  },
  {
    id: "03",
    title: "α & β - ミニマル・クリスマス",
    thumb: "/images/alphabeta/gallery/thumb_03.webp",
    image: "/images/alphabeta/gallery/03.webp",
    tools: ["ChatGPT", "Gemini Nanobanana"],
    category: "Hybrid Workflow",
    summary: "αとβのキャラクターをアレンジしたミニマルイラスト。デザイン方向性をYAML形式で指示することで、一貫したデザインが実現。",
    promptNote: [
      "Holiday theme",
      "Minimalist flat art",
      "Vector character style",
      "Yellow background"
    ],
    promptExample: "Alpha and Beta together in a minimalist Christmas scene, floating ornaments, bright yellow background, simple flat illustration, text 'I wish you a merry Christmas'.",
  },
  {
    id: "04",
    title: "継承体α - クレイアニメ風表現",
    thumb: "/images/alphabeta/gallery/thumb_04.webp",
    image: "/images/alphabeta/gallery/04.webp",
    tools: ["Gemini Nanobanana", "ChatGPT"],
    category: "Creative Test",
    summary: "αのクレイアニメ風3D表現イラスト。2Dで生成→クレイアニメ風変換指示（プロンプト）によって、3Dのような画像を生成。",
    promptNote: [
      "Claymation texture",
      "Top-down view",
      "Tactile materials",
      "Notebook & Tech scattering"
    ],
    promptExample: "Top-down view of Alpha in claymation style, tactile material textures, lying on wood floor, notebooks and headphones scattered around, high detail 3D render.",
  }
];
---

<section class="py-24 bg-brand-beige overflow-hidden">
  <div class="container mx-auto px-8" x-data="{ open: false, activeItem: null }">
    <div class="mb-16">
      <h2 class="text-sm font-bold tracking-[0.3em] uppercase text-brand-pink-accent/80 mb-4 text-center md:text-left">Gallery</h2>
      <h3 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 italic text-center md:text-left">
        AIとの対話が生む、<br class="md:hidden" />新しい視覚言語の断片
      </h3>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {items.map((item) => (
        <button 
          @click={`activeItem = ${JSON.stringify(item)}; open = true`}
          class="group relative aspect-square rounded-[2rem] overflow-hidden bg-brand-pink/5 border border-brand-pink/10 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 text-left"
        >
          <img 
            src={item.thumb} 
            alt={item.title} 
            class="w-full h-full object-cover grayscale brightness-110 group-hover:grayscale-0 group-hover:scale-110 group-hover:brightness-100 transition-all duration-700"
          />
          <div class="absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-black/80 via-black/40 to-transparent translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="text-[10px] font-bold tracking-widest text-brand-pink/60 uppercase mb-1 block">{item.category}</span>
            <h4 class="text-white font-serif font-bold text-sm italic line-clamp-1">{item.title}</h4>
          </div>
        </button>
      ))}
    </div>

    <!-- Modal Backdrop -->
    <template x-teleport="body">
      <div 
        x-show="open" 
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-8 bg-brand-gray/95 backdrop-blur-xl"
        @keydown.escape.window="open = false"
      >
        <!-- Modal Content -->
        <div 
          @click.away="open = false"
          class="relative w-full max-w-6xl max-h-[90vh] bg-brand-beige rounded-[3rem] shadow-2xl overflow-hidden flex flex-col md:flex-row"
        >
          <!-- Close Button -->
          <button 
            @click="open = false"
            class="absolute top-6 right-6 z-10 p-4 rounded-full bg-white/10 hover:bg-white/20 text-brand-beige border border-white/20 transition-all hover:scale-110"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>

          <!-- Image Area -->
          <div class="flex-1 bg-black flex items-center justify-center p-4">
            <img 
              :src="activeItem?.image" 
              :alt="activeItem?.title" 
              class="max-w-full max-h-full object-contain rounded-xl"
            />
          </div>

          <!-- Info Area -->
          <div class="w-full md:w-[400px] bg-brand-beige p-8 md:p-12 overflow-y-auto font-serif italic text-brand-gray">
            <div class="space-y-8">
              <div>
                <h2 class="text-3xl font-bold text-gray-900 leading-tight mb-4" x-text="activeItem?.title">Title</h2>
                <div class="flex flex-wrap gap-2">
                  <template x-for="tool in activeItem?.tools">
                    <span class="px-3 py-1 bg-brand-pink/10 rounded-full text-[10px] font-bold tracking-widest text-brand-pink-accent uppercase" x-text="tool">TOOL</span>
                  </template>
                </div>
              </div>

              <div class="space-y-4">
                <h3 class="text-sm font-bold tracking-widest uppercase text-gray-900 border-b border-brand-pink/20 pb-2">Summary</h3>
                <p class="text-sm leading-relaxed" x-text="activeItem?.summary">Summary text goes here.</p>
              </div>

              <div class="space-y-4">
                <h3 class="text-sm font-bold tracking-widest uppercase text-gray-900 border-b border-brand-pink/20 pb-2">Prompt Notes</h3>
                <ul class="space-y-2">
                  <template x-for="note in activeItem?.promptNote">
                    <li class="text-xs flex items-center gap-2">
                      <span class="w-1.5 h-1.5 bg-brand-pink rotate-45"></span>
                      <span x-text="note">Note</span>
                    </li>
                  </template>
                </ul>
              </div>

              <template x-if="activeItem?.promptExample">
                <div class="space-y-4">
                  <h3 class="text-sm font-bold tracking-widest uppercase text-gray-900 border-b border-brand-pink/20 pb-2">Prompt Example</h3>
                  <div class="p-4 bg-brand-gray/5 rounded-2xl border border-brand-pink/10 text-[11px] font-mono non-italic break-all select-all hover:bg-white transition-colors cursor-copy" x-text="activeItem?.promptExample">
                    Prompt text...
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>
    </template>
  </div>
</section>
