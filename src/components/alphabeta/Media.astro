---
const videos = [
  { id: 'CHuxTm6zLvg', title: 'αβlabプロモテストムービー' }
];

const novelSeries = {
  title: "遠くまで行くもの",
  url: "https://tales.note.com/ryojihido/w7gsla7j1znz3?ss=wsl64yqt4luz7q1",
  description: "αとβの物語を深掘りする連載小説をTales（note）で展開中です。"
};
---

<section class="py-24 bg-brand-surface overflow-hidden">
  <div class="container mx-auto px-8 max-w-5xl">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
      
      <!-- YouTube Section -->
      <div class="space-y-12">
        <div class="space-y-4">
          <h2 class="text-sm font-bold tracking-[0.3em] uppercase text-brand-pink-accent/80">Featured Videos</h2>
          <p class="text-brand-gray/60 font-serif italic text-sm italic">αとβの動く姿や世界観を紹介します。</p>
        </div>
        
        <div class="space-y-8">
          {videos.map(video => (
            <div class="space-y-4">
              <div class="group relative bg-brand-beige p-2 rounded-[2.5rem] border border-brand-pink/20 shadow-sm hover:shadow-2xl transition-all duration-500 overflow-hidden">
                <div class="aspect-video rounded-[2rem] overflow-hidden bg-gray-100 relative">
                  <iframe 
                    class="absolute inset-0 w-full h-full"
                    src={`https://www.youtube.com/embed/${video.id}`}
                    title={video.title}
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                    referrerpolicy="strict-origin-when-cross-origin" 
                    allowfullscreen
                  ></iframe>
                </div>
                <!-- Decorative indicator borrowed from top page style -->
                <div class="absolute top-6 right-8 flex gap-2 opacity-20 group-hover:opacity-100 transition-opacity">
                  <div class="w-2.5 h-2.5 rounded-full bg-brand-pink-accent"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-brand-pink"></div>
                </div>
              </div>
              <p class="text-xs font-serif italic text-brand-gray/60 px-6">
                {video.title}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- Novel Section -->
      <div class="flex flex-col justify-center space-y-12">
        <div class="space-y-4">
          <h2 class="text-sm font-bold tracking-[0.3em] uppercase text-brand-pink-accent/80">Novel Series</h2>
          <p class="text-brand-gray/60 font-serif italic text-sm italic">
            Read the narrative.
          </p>
        </div>

        <a 
          href={novelSeries.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative block p-10 bg-white border border-brand-pink/20 rounded-[3rem] shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden"
        >
          <!-- Decoration -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-brand-pink/5 rounded-full -mr-16 -mt-16 transition-transform group-hover:scale-150 duration-700"></div>
          
          <div class="relative z-10 space-y-6">
            <div class="inline-block px-4 py-1.5 text-[10px] font-bold tracking-[0.2em] text-white bg-brand-pink-accent rounded-full uppercase">
              Tales on note
            </div>
            <h4 class="text-3xl font-serif font-bold text-gray-900 italic">
              {novelSeries.title}
            </h4>
            <p class="text-brand-gray/80 font-serif leading-relaxed italic text-sm">
              {novelSeries.description}
            </p>
            <div class="pt-4 flex items-center gap-3 text-[10px] font-bold tracking-[0.3em] uppercase text-brand-pink-accent">
              Read Online
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>
