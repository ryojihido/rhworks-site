---
const characters = [
  {
    name: "α（アルファ）— 継承体AI",
    description: "天真爛漫で好奇心旺盛。感情で突っ走るムードメーカー。キョトンとした目がトレードマーク。",
    image: "/images/alphabeta/char_a.webp"
  },
  {
    name: "β（ベタ）— 編纂体AI",
    description: "物静かに見えて、じつは野心家。論理とドライな一言でαを振り回す。目は開かない。",
    image: "/images/alphabeta/char_b.webp"
  }
];

const downloadPath = "/downloads/alphabeta-character-pack-v1.0.zip";
const previewVideoPath = "/videos/alphabeta/side-by-side-sequential.mp4";
---
<section class="py-20 bg-brand-surface">
  <div class="container mx-auto px-8 max-w-4xl">
    <h2 class="text-sm font-bold tracking-[0.3em] uppercase text-brand-pink-accent/80 mb-12">Character Introduction</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {characters.map(char => (
        <div class="group space-y-4">
          <div class="aspect-[3/4] rounded-[2rem] bg-brand-pink/5 border border-brand-pink/10 overflow-hidden relative shadow-sm transition-all duration-500 group-hover:shadow-xl">
            <img
              src={char.image}
              alt={char.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="px-4">
            <h3 class="text-xl font-serif font-bold text-gray-900 mb-2 truncate group-hover:text-brand-pink-accent transition-colors">
              {char.name}
            </h3>
            <p class="text-sm text-brand-gray/70 leading-relaxed italic">
              {char.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- 4-koma manga -->
    <figure class="mt-16 max-w-md mx-auto">
      <div class="overflow-hidden rounded-[2rem] border border-brand-pink/20 bg-white shadow-sm">
        <img
          src="/images/alphabeta/character-4koma.webp"
          alt="αとβの関係を描いたAI生成4コマ漫画。悪役令嬢ものを提案するαと、プロンプトを書き換えて主従を逆転させるβ。"
          class="w-full"
          loading="lazy"
          decoding="async"
        />
      </div>
      <figcaption class="mt-4 text-center text-xs font-serif italic text-brand-gray/60">
        この4コマもAI生成（GPT Image 2）— ふたりの関係は、だいたいこんな感じです。
      </figcaption>
    </figure>

    <div class="mt-16 text-center max-w-lg mx-auto space-y-2">
      <p class="text-base font-serif italic text-brand-gray/70">
        素材はふたり分。GeminiやChatGPTに読み込ませれば、<a href="#gallery" class="underline decoration-brand-pink/40 underline-offset-4 hover:text-brand-pink-accent transition-colors">Gallery</a>のような遊びがすぐ始められます。
      </p>
      <p class="text-sm font-serif italic text-brand-gray/55">
        入力したデータがAIの学習に使われるサービスでも、使われないサービスでも、どちらでも構いません。
      </p>
    </div>

    <!-- Download Banner -->
    <div class="mt-10">
      <a 
        href={downloadPath}
        download
        class="group relative block p-8 md:p-12 overflow-hidden rounded-[2.5rem] bg-brand-gray text-brand-beige shadow-2xl transition-all duration-500 hover:-translate-y-2 hover:shadow-brand-pink/20"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-brand-pink/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        <div class="relative flex flex-col md:flex-row items-center justify-between gap-8">
          <div class="space-y-2 text-center md:text-left">
            <h3 class="text-2xl md:text-3xl font-serif font-bold italic tracking-tight">
              Download alphabeta-character-pack-v1.0.zip
            </h3>
            <p class="text-brand-beige/50 text-xs tracking-[0.2em] uppercase font-bold">
              Size: ~25MB / Format: PNG
            </p>
          </div>
          <div class="flex items-center gap-4 px-8 py-4 bg-brand-beige text-brand-gray rounded-2xl font-bold text-xs tracking-[0.2em] uppercase transition-all duration-300 group-hover:bg-white group-hover:scale-105">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            Download Now
          </div>
        </div>
      </a>
      <p class="mt-6 text-[10px] text-brand-gray/40 text-center uppercase tracking-widest leading-relaxed">
        ※ ダウンロードを開始することで、<a href="/alphabeta/guidelines/" class="text-brand-pink-accent hover:underline">利用規約</a>に同意したものとみなされます
      </p>
    </div>

    <div class="mt-10 space-y-4">
      <div class="group relative overflow-hidden rounded-[2.5rem] border border-brand-pink/20 bg-white p-2 shadow-sm transition-all duration-500 hover:shadow-2xl">
        <div class="overflow-hidden rounded-[2rem] bg-brand-gray/5">
          <video
            src={previewVideoPath}
            class="aspect-video w-full bg-brand-gray/10 object-contain brightness-[0.96]"
            controls
            preload="metadata"
            playsinline
            aria-label="αβVoiceSample（voiceデザイン：IrodoriTTS）"
          ></video>
        </div>

        <div class="pointer-events-none absolute right-8 top-6 flex gap-2 opacity-20 transition-opacity group-hover:opacity-100">
          <div class="h-2.5 w-2.5 rounded-full bg-brand-pink-accent"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-brand-pink"></div>
        </div>
      </div>

      <p class="px-6 text-xs font-serif italic text-brand-gray/60">
        αβVoiceSample（voiceデザイン：
        <a
          href="https://github.com/Aratako/Irodori-TTS"
          target="_blank"
          rel="noopener noreferrer"
          class="underline decoration-brand-pink/40 underline-offset-4 transition-colors hover:text-brand-pink-accent"
        >
          IrodoriTTS
        </a>
        ）
      </p>
    </div>
  </div>
</section>
